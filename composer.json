{
  "name": "brikocode/framework",
  "description": "Brikocode — framework PHP minimaliste à saveur ivoirienne",
  "keywords": ["framework", "php", "africa", "cote-d-ivoire", "minimal", "rest", "api"],
  "homepage": "https://github.com/devKonan/framework",
  "license": "MIT",
  "authors": [
    {
      "name": "Brikocode",
      "email": "kasseberangerkonan@gmail.com",
      "role": "Créateur"
    }
  ],
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "Briko\\Http\\":        "http/",
      "Briko\\Routing\\":     "routing/",
      "Briko\\Database\\":    "database/",
      "Briko\\Sms\\":         "sms/",
      "Briko\\Mail\\":        "mail/",
      "Briko\\Console\\":     "console/",
      "Briko\\Foundation\\":  "foundation/",
      "App\\":                "app/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "foundation/helpers.php"
    ]
  },
  "minimum-stability": "stable"
}
