APP_NAME=Brikocode
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PORT=8000

LOG_LEVEL=DEBUG
# En production : LOG_LEVEL=WARNING

# ── SMS (tamtam) ──────────────────────────────────────────────────────────────
SMS_DRIVER=log
# Drivers disponibles : log | africastalking | twilio | http
SMS_FROM=Brikocode
OTP_MESSAGE="Votre code de vérification : "

# Africa's Talking (africastalking.com — meilleur choix pour l'Afrique)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SANDBOX=true

# Twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# HTTP générique (Orange CI, MTN, Moov, etc.)
SMS_HTTP_URL=
SMS_HTTP_FIELD_TO=to
SMS_HTTP_FIELD_MSG=message
SMS_HTTP_FIELD_FROM=from
SMS_HTTP_AUTH_FIELD=apikey
SMS_HTTP_AUTH_VALUE=
SMS_HTTP_SUCCESS_CODE=200

# ── MAILING (courrier) ────────────────────────────────────────────────────────
MAIL_DRIVER=log
# Drivers disponibles : log | smtp | sendgrid | mailgun

MAIL_FROM_ADDRESS=noreply@brikocode.ci
MAIL_FROM_NAME=Brikocode
MAIL_REPLY_TO=

# SMTP (Gmail, Outlook, OVH, Amazon SES SMTP...)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
# Valeurs possibles : tls | ssl | none

# SendGrid (API HTTP)
SENDGRID_API_KEY=

# Mailgun (API HTTP)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us
# Valeurs possibles : us | eu

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=brikocode
DB_USER=root
DB_PASS=

# Pour SQLite : mettre DB_DRIVER=sqlite et DB_PATH=database/db.sqlite
# DB_DRIVER=sqlite
# DB_PATH=database/db.sqlite
